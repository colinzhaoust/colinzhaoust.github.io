{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4blue2brown.local/schemas/paper-media/public-manifest-0.1.0.schema.json",
  "title": "Public paper media evidence projection 0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "canonical_manifest_hash", "projection_policy_id", "generated_at", "redaction_summary",
    "run_id", "cell_id", "thread", "started_at", "ended_at", "status", "pipeline", "lineage", "completion",
    "artifacts", "claims", "reviews", "cost", "license"
  ],
  "properties": {
    "schema_version": {"const": "paper-media-public-manifest/0.1.0"},
    "canonical_manifest_hash": {"$ref": "#/$defs/hash"},
    "projection_policy_id": {"const": "paper-media-public-projection/0.1.0"},
    "generated_at": {"type": "string", "format": "date-time"},
    "redaction_summary": {
      "type": "object", "additionalProperties": false, "required": ["omitted_fields", "omitted_artifacts"],
      "properties": {"omitted_fields": {"type": "integer", "minimum": 0}, "omitted_artifacts": {"type": "integer", "minimum": 0}}
    },
    "run_id": {"type": "string"}, "cell_id": {"type": "string"},
    "thread": {"enum": ["real_video_pipelines", "paper_to_slides", "slides_plus_manim", "backtranslation"]},
    "started_at": {"type": "string", "format": "date-time"}, "ended_at": {"type": "string", "format": "date-time"},
    "status": {"enum": ["completed", "stopped", "failed"]},
    "pipeline": {
      "type": "object", "additionalProperties": false, "required": ["id", "variant", "repository", "commit_sha"],
      "properties": {"id": {"type": "string"}, "variant": {"type": "string"}, "repository": {"type": "string", "format": "uri", "pattern": "^https://"}, "commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}}
    },
    "lineage": {"$ref": "#/$defs/public_lineage"},
    "completion": {
      "type": "object", "additionalProperties": false, "required": ["contract_id", "derived_value"],
      "properties": {"contract_id": {"type": "string"}, "derived_value": {"$ref": "#/$defs/completion"}}
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["artifact_id", "role", "public_path", "content_hash", "media_type", "completion", "lineage"],
        "properties": {"artifact_id": {"type": "string"}, "role": {"type": "string"}, "public_path": {"$ref": "#/$defs/repo_path"}, "content_hash": {"$ref": "#/$defs/hash"}, "media_type": {"type": "string"}, "completion": {"$ref": "#/$defs/completion"}, "lineage": {"$ref": "#/$defs/public_lineage"}}
      }
    },
    "claims": {
      "type": "array",
      "items": {"type": "object", "additionalProperties": false, "required": ["claim_id", "label", "statement", "evidence_refs", "observed_at"], "properties": {"claim_id": {"type": "string"}, "label": {"enum": ["MEASURED", "OBSERVED", "REPORTED", "ESTIMATE", "PLANNED", "DECISION"]}, "statement": {"type": "string"}, "evidence_refs": {"type": "array", "items": {"type": "string"}}, "observed_at": {"type": "string", "format": "date-time"}}}
    },
    "reviews": {
      "type": "array",
      "items": {"type": "object", "additionalProperties": false, "required": ["review_id", "subject_ref", "rubric_id", "evaluator_type", "result", "evidence_refs", "reviewed_at"], "properties": {"review_id": {"type": "string"}, "subject_ref": {"type": "string"}, "rubric_id": {"type": "string"}, "evaluator_type": {"enum": ["automatic", "human"]}, "result": {"enum": ["pass", "fail"]}, "evidence_refs": {"type": "array", "items": {"type": "string"}}, "reviewed_at": {"type": "string", "format": "date-time"}}}
    },
    "cost": {
      "type": "object", "additionalProperties": false, "required": ["measured_usd", "estimated_usd", "coverage"],
      "properties": {"measured_usd": {"type": ["number", "null"], "minimum": 0}, "estimated_usd": {"type": ["number", "null"], "minimum": 0}, "coverage": {"type": "array", "items": {"type": "string"}}}
    },
    "license": {
      "type": "object", "additionalProperties": false, "required": ["declared_spdx", "redistribution_conclusion", "license_text_hash"],
      "properties": {"declared_spdx": {"type": ["string", "null"]}, "redistribution_conclusion": {"enum": ["allowed", "allowed_with_notice"]}, "license_text_hash": {"$ref": "#/$defs/hash"}}
    }
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "repo_path": {"type": "string", "minLength": 1, "not": {"pattern": "(^/|^[A-Za-z]:[\\\\/]|(^|/)\\.\\.(/|$)|^file:)"}},
    "completion": {"enum": ["full", "partial", "smoke", "failed", "placeholder"]},
    "public_lineage": {
      "type": "object", "additionalProperties": false,
      "required": ["implementation_origin", "input_contract_mode", "patch_level", "patchset_hash", "derivation_stage", "parent_artifact_refs"],
      "properties": {
        "implementation_origin": {"enum": ["upstream_repository", "project_reimplementation", "project_native", "synthetic_fixture", "human_authored_reference"]},
        "input_contract_mode": {"enum": ["native", "adapted"]}, "patch_level": {"enum": ["none", "config_only", "compatibility", "method_change"]},
        "patchset_hash": {"$ref": "#/$defs/hash"}, "derivation_stage": {"enum": ["source", "generated", "rendered", "composed", "one_shot", "self_refined"]},
        "parent_artifact_refs": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["artifact_id", "relation"], "properties": {"artifact_id": {"type": "string"}, "relation": {"enum": ["derived_from", "rendered_from", "composed_from", "refined_from"]}}}
      }
    }
  }
}
}

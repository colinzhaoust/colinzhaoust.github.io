{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4blue2brown.local/schemas/slides-manim/slide-ir-0.1.0.schema.json",
  "title": "Slides + Manim SlideIR 0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "slide_id", "title", "intent", "completion", "claims", "layout",
    "citations", "static_elements", "speaker_notes", "artifacts", "animation_slots", "planned_slots"
  ],
  "properties": {
    "schema_version": {"const": "slide-ir/0.1.0"},
    "slide_id": {"$ref": "#/$defs/id"},
    "title": {"type": "string", "minLength": 1},
    "intent": {"enum": ["methodology", "architecture", "performance", "comparison", "summary"]},
    "completion": {"enum": ["full", "partial", "smoke", "failed", "placeholder"]},
    "claims": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
    "layout": {
      "type": "object", "additionalProperties": false,
      "required": ["canvas", "template_id"],
      "properties": {
        "canvas": {"const": "16:9"},
        "template_id": {"$ref": "#/$defs/id"}
      }
    },
    "citations": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["citation_id", "label", "url", "revision", "locator"],
        "properties": {
          "citation_id": {"$ref": "#/$defs/id"}, "label": {"type": "string", "minLength": 1},
          "url": {"type": "string", "format": "uri", "pattern": "^https://"},
          "revision": {"type": "string", "minLength": 1}, "locator": {"type": "string", "minLength": 1}
        }
      }
    },
    "static_elements": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["element_id", "kind", "content", "region"],
        "properties": {
          "element_id": {"$ref": "#/$defs/id"}, "kind": {"enum": ["title", "body", "formula", "citation", "badge"]},
          "content": {"type": "string", "minLength": 1}, "region": {"type": "string", "minLength": 1}
        }
      }
    },
    "speaker_notes": {"type": "string"},
    "artifacts": {
      "type": "array", "minItems": 3,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["artifact_id", "role", "path", "content_hash", "media_type", "completion", "validation_status", "understandable_without_playback", "lineage"],
        "properties": {
          "artifact_id": {"$ref": "#/$defs/id"},
          "role": {"enum": ["scene_ir", "rendered_video", "static_fallback", "caption_track"]},
          "path": {"$ref": "#/$defs/repo_path"},
          "content_hash": {"$ref": "#/$defs/hash"},
          "media_type": {"type": "string", "minLength": 1},
          "completion": {"enum": ["full", "partial", "smoke", "failed", "placeholder"]},
          "validation_status": {"enum": ["pass", "fail", "not_run"]},
          "understandable_without_playback": {"type": "boolean"},
          "lineage": {
            "type": "object", "additionalProperties": false,
            "required": ["source_run_ref", "source_commit", "derivation_stage"],
            "properties": {
              "source_run_ref": {"$ref": "#/$defs/id"}, "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
              "derivation_stage": {"enum": ["generated", "rendered", "static_fallback", "embedded"]}
            }
          }
        }
      }
    },
    "animation_slots": {
      "type": "array", "minItems": 1,
      "items": {"$ref": "https://4blue2brown.local/schemas/slides-manim/animation-slot-0.1.0.schema.json"}
    },
    "planned_slots": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["planned_slot_id", "status", "semantic_purpose", "reason", "missing_requirements", "expected_slot_contract_version"],
        "properties": {
          "planned_slot_id": {"$ref": "#/$defs/id"}, "status": {"const": "planned_missing"},
          "semantic_purpose": {"enum": ["architecture_dataflow", "performance_comparison", "ablation", "uncertainty"]},
          "reason": {"type": "string", "minLength": 1},
          "missing_requirements": {"type": "array", "items": {"enum": ["scene_ir", "rendered_artifact", "static_fallback", "poster", "review"]}, "minItems": 1, "uniqueItems": true},
          "expected_slot_contract_version": {"const": "animation-slot/0.1.0"}
        }
      }
    }
  },
  "$defs": {
    "id": {"type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"},
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "repo_path": {"type": "string", "minLength": 1, "not": {"pattern": "(^/|^[A-Za-z]:[\\\\/]|(^|[/\\\\])\\.\\.([/\\\\]|$)|^~|^file:)"}}
  }
}

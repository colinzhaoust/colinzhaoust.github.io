{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4blue2brown.local/schemas/formula-explainer/scene-ir-0.1.0.schema.json",
  "title": "Bottom-up formula explainer SceneIR 0.1.0",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "scene_id", "canonical_node_id", "formula_ir_ref", "title", "aspect_ratio", "render_targets", "beats", "static_fallback_plan"],
  "properties": {
    "schema_version": {"const": "scene-ir/0.1.0"}, "scene_id": {"$ref": "#/$defs/id"}, "canonical_node_id": {"$ref": "#/$defs/id"},
    "formula_ir_ref": {"type": "string", "pattern": "^(?!/)(?!.*\\.\\.).+\\.json$"}, "title": {"type": "string", "minLength": 1},
    "aspect_ratio": {"enum": ["16:9", "4:3", "1:1", "9:16"]},
    "render_targets": {"type": "array", "items": {"enum": ["mp4", "poster_png"]}, "minItems": 1, "uniqueItems": true},
    "beats": {
      "type": "array", "minItems": 3,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["beat_id", "operation_ref", "primitive_ref", "state", "caption", "duration_seconds", "narration_hook"],
        "properties": {
          "beat_id": {"$ref": "#/$defs/id"}, "operation_ref": {"$ref": "#/$defs/id"}, "primitive_ref": {"$ref": "#/$defs/id"},
          "state": {"enum": ["initial", "intermediate", "terminal"]}, "caption": {"type": "string", "minLength": 1},
          "duration_seconds": {"type": "number", "exclusiveMinimum": 0}, "narration_hook": {"type": "string"}
        }
      }
    },
    "static_fallback_plan": {"type": "string", "minLength": 1}
  },
  "$defs": {"id": {"type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"}}
}

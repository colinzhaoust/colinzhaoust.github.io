{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4blue2brown.local/schemas/formula-explainer/primitive-registry-0.1.0.schema.json",
  "title": "Formula explainer Manim primitive registry 0.1.0",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "manim_compatibility", "primitives"],
  "properties": {
    "schema_version": {"const": "primitive-registry/0.1.0"},
    "manim_compatibility": {
      "type": "object", "additionalProperties": false,
      "required": ["validated_render_versions", "minimum_supported_version", "render_evidence_refs", "statement"],
      "properties": {
        "validated_render_versions": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true},
        "minimum_supported_version": {"type": ["string", "null"]},
        "render_evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true},
        "statement": {"type": "string", "minLength": 1}
      }
    },
    "primitives": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["primitive_id", "canonical_node_id", "version", "origin", "origin_badge", "source_symbol", "source_revision", "operations", "inputs", "outputs", "visual_states", "animation_contract", "status", "used_by", "verification", "limitations"],
        "properties": {
          "primitive_id": {"$ref": "#/$defs/id"}, "canonical_node_id": {"$ref": "#/$defs/id"}, "version": {"type": "string", "minLength": 1},
          "origin": {"enum": ["built_in", "project_reusable", "generated_one_off", "missing_planned"]},
          "origin_badge": {
            "type": "object", "additionalProperties": false, "required": ["label", "color", "icon"],
            "properties": {"label": {"type": "string", "minLength": 1}, "color": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"}, "icon": {"type": "string", "minLength": 1}}
          },
          "source_symbol": {"type": ["string", "null"]}, "source_revision": {"type": "string", "minLength": 1},
          "operations": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
          "inputs": {"type": "array", "items": {"type": "string"}}, "outputs": {"type": "array", "items": {"type": "string"}},
          "visual_states": {
            "type": "object", "additionalProperties": false, "required": ["initial", "intermediate", "terminal"],
            "properties": {"initial": {"type": "string"}, "intermediate": {"type": "string"}, "terminal": {"type": "string"}}
          },
          "animation_contract": {"type": "string", "minLength": 1}, "status": {"enum": ["available", "candidate", "missing"]},
          "used_by": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
          "verification": {
            "type": "object", "additionalProperties": false, "required": ["test_refs", "golden_scene_refs"],
            "properties": {
              "test_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
              "golden_scene_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
            }
          },
          "limitations": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  },
  "$defs": {"id": {"type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"}}
}

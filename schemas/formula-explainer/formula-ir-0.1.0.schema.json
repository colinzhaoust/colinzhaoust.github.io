{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4blue2brown.local/schemas/formula-explainer/formula-ir-0.1.0.schema.json",
  "title": "Bottom-up formula explainer FormulaIR 0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "formula_id", "canonical_node_id", "topic_id", "paper_family_id",
    "title", "display", "source_anchor", "atoms", "operations", "output_ref", "code_mappings"
  ],
  "properties": {
    "schema_version": {"const": "formula-ir/0.1.0"},
    "formula_id": {"$ref": "#/$defs/id"},
    "canonical_node_id": {"$ref": "#/$defs/id"},
    "topic_id": {"$ref": "#/$defs/id"},
    "paper_family_id": {"$ref": "#/$defs/id"},
    "title": {"type": "string", "minLength": 1},
    "display": {
      "type": "object", "additionalProperties": false,
      "required": ["latex", "plain_text"],
      "properties": {"latex": {"type": "string", "minLength": 1}, "plain_text": {"type": "string", "minLength": 1}}
    },
    "source_anchor": {"$ref": "#/$defs/source_anchor"},
    "atoms": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["atom_id", "symbol", "semantic_type", "role"],
        "properties": {
          "atom_id": {"$ref": "#/$defs/id"}, "symbol": {"type": "string", "minLength": 1},
          "semantic_type": {"enum": ["scalar", "vector", "matrix", "distribution", "index", "data", "value"]},
          "role": {"type": "string", "minLength": 1}
        }
      }
    },
    "operations": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["operation_id", "canonical_node_id", "operation_type", "input_refs", "output_ref", "primitive_ref", "mapping_state", "evidence_refs"],
        "properties": {
          "operation_id": {"$ref": "#/$defs/id"}, "canonical_node_id": {"$ref": "#/$defs/id"},
          "operation_type": {"enum": ["add", "subtract", "multiply", "divide", "matmul", "dot", "scale", "exp", "softmax", "log", "sigmoid", "normalize", "expectation", "kl", "ess", "clip", "minimum", "stop_gradient", "rotation", "concatenate", "linear_projection", "sine", "cosine", "weighted_sum"]},
          "input_refs": {"type": "array", "items": {"$ref": "#/$defs/id"}, "minItems": 1},
          "output_ref": {"$ref": "#/$defs/id"}, "primitive_ref": {"$ref": "#/$defs/id"},
          "mapping_state": {"enum": ["candidate", "confirmed", "rejected", "unresolved"]},
          "evidence_refs": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "output_ref": {"$ref": "#/$defs/id"},
    "code_mappings": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["code_node_id", "repository_revision", "path", "symbol", "line_start", "line_end", "match_state", "evidence_refs"],
        "properties": {
          "code_node_id": {"$ref": "#/$defs/id"}, "repository_revision": {"type": "string", "minLength": 1},
          "path": {"type": "string", "pattern": "^(?!/)(?!.*\\.\\.).+$"}, "symbol": {"type": "string", "minLength": 1},
          "line_start": {"type": "integer", "minimum": 1}, "line_end": {"type": "integer", "minimum": 1},
          "match_state": {"enum": ["candidate", "confirmed", "rejected", "unresolved"]},
          "evidence_refs": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  },
  "$defs": {
    "id": {"type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"},
    "source_anchor": {
      "type": "object", "additionalProperties": false,
      "required": ["source_id", "source_url", "revision", "content_hash", "locator", "verification"],
      "properties": {
        "source_id": {"$ref": "#/$defs/id"}, "source_url": {"type": "string", "format": "uri", "pattern": "^https://"},
        "revision": {"type": "string", "minLength": 1}, "content_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "locator": {"type": "string", "minLength": 1}, "verification": {"enum": ["primary_source_visual", "primary_source_text", "secondary_source", "unresolved"]}
      }
    }
  }
}

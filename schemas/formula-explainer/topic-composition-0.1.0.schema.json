{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4blue2brown.local/schemas/formula-explainer/topic-composition-0.1.0.schema.json",
  "title": "Bottom-up formula explainer topic composition 0.1.0",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "topic_id", "paper_family_id", "title", "canonical_node_id", "formula_ir_refs", "scene_ir_refs", "composition", "claim_context", "code_transition_policy"],
  "properties": {
    "schema_version": {"const": "topic-composition/0.1.0"}, "topic_id": {"$ref": "#/$defs/id"}, "paper_family_id": {"$ref": "#/$defs/id"},
    "title": {"type": "string", "minLength": 1}, "canonical_node_id": {"$ref": "#/$defs/id"},
    "formula_ir_refs": {"type": "array", "items": {"type": "string", "pattern": "^(?!/)(?!.*\\.\\.).+\\.json$"}, "minItems": 1, "uniqueItems": true},
    "scene_ir_refs": {"type": "array", "items": {"type": "string", "pattern": "^(?!/)(?!.*\\.\\.).+\\.json$"}, "minItems": 1, "uniqueItems": true},
    "composition": {
      "type": "array", "minItems": 1,
      "items": {"type": "object", "additionalProperties": false, "required": ["order", "scene_ir_ref", "transition"], "properties": {"order": {"type": "integer", "minimum": 1}, "scene_ir_ref": {"type": "string"}, "transition": {"enum": ["claim_context", "formula_dependency", "code_grounding", "comparison", "summary"]}}}
    },
    "claim_context": {"type": "string", "minLength": 1}, "code_transition_policy": {"enum": ["exact_anchor", "candidate_anchor", "unresolved_visible", "not_applicable"]}
  },
  "$defs": {"id": {"type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"}}
}
